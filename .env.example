# ViFoodLabel Runtime Configuration
# Copy to .env and adjust values for each machine.

PROJECT_ROOT=.
PYTHONPATH=.

# Data paths
LABEL_STUDIO_EXPORT=data/label_studio/data.json
RAW_IMAGES_DIR=data/raw
PROCESSED_DIR=data/processed
THUMBNAIL_DIR=data/thumbnail

# Training output
OUTPUT_DIR=results

# Default models
PHOBERT_MODEL=vinai/phobert-base
LAYOUTLMV3_MODEL=microsoft/layoutlmv3-base
OCR_DET_ARCH=db_resnet50
OCR_FILTER_NOISE=1
OCR_NOISE_MIN_CONF=0.45

# NER settings
NER_ENABLE_CHUNKING=1
NER_CHUNK_WORDS=120
NER_CHUNK_OVERLAP=30
NER_ENABLE_B_REPAIR=0
NER_MERGE_PROFILE=v3

# API Keys (for Tier C zero-shot MLLM evaluation)
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Optional runtime settings
CUDA_VISIBLE_DEVICES=0
HF_HOME=.cache/huggingface
